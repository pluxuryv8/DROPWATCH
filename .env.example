TELEGRAM_TOKEN=CHANGE_ME
OWNER_TG_ID=123456789
DATABASE_URL=sqlite+aiosqlite:///./dropwatch.db
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_TASK_INTERVAL_SEC=30
SCHEDULER_TICK_SEC=10
GLOBAL_POLL_INTERVAL_SEC=120
AGGREGATE_THRESHOLD=3
MIN_REQUEST_GAP_SEC=30
FETCHER=avito_search
LOG_LEVEL=INFO

# Avito search (HTML)
AVITO_PROXY=
AVITO_PROXY_CHANGE_URL=
AVITO_COOKIES_API_KEY=
AVITO_USE_WEBDRIVER=true
AVITO_COOKIES_PATH=./avito_cookies.json
AVITO_MAX_PAGES=1
AVITO_PAUSE_SEC=2
AVITO_MAX_RETRIES=5
AVITO_REQUEST_TIMEOUT_SEC=20
AVITO_IMPERSONATE=chrome
AVITO_PARSE_VIEWS=false
AVITO_VIEWS_DELAY_SEC=0.5
AVITO_IGNORE_RESERVED=false
AVITO_IGNORE_PROMOTION=false
AVITO_MAX_AGE_SEC=0
AVITO_SELLER_BLACKLIST=
AVITO_KEYWORDS_WHITELIST=
AVITO_KEYWORDS_BLACKLIST=
AVITO_GEO_FILTER=

# Optional: use mock data for testing
MOCK_DATA_PATH=./mock_listings.json
